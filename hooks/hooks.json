{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/pre-commit-format.js\""
          }
        ],
        "description": "Format staged Go/proto files before commit (git commit, gt create/modify/amend)"
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/pre-edit-generated-guard.js\""
          }
        ],
        "description": "Warn when editing generated files (proto, ent, gqlgen)"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/post-edit-format.js\""
          }
        ],
        "description": "Auto-format JS/TS files after edits (Biome or Prettier)"
      }
    ]
  }
}
